{
  "name": "@horizontal-ph/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":           "tsx watch src/app.ts",
    "build":         "tsc",
    "start":         "node dist/app.js",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "migrate":       "node scripts/run_migrations.js",
    "migrate:reset": "node scripts/reset_and_migrate.js",
    "jobs:cobranza": "tsx -e \"import('./src/jobs/cobranza.job.js').then(m => m.runCobranzaJob())\"",
    "jobs:notif":    "tsx -e \"import('./src/jobs/notificacion.job.js').then(m => m.runNotificacionJob())\"",
    "jobs:informe":  "tsx -e \"import('./src/jobs/informe.job.js').then(m => m.runInformeJob())\""
  },
  "dependencies": {
    "fastify":              "^4.28.0",
    "@fastify/cors":        "^9.0.0",
    "@fastify/jwt":         "^8.0.0",
    "@fastify/swagger":     "^8.15.0",
    "@fastify/swagger-ui":  "^4.1.0",
    "kysely":               "^0.27.0",
    "pg":                   "^8.12.0",
    "redis":                "^4.7.0",
    "bullmq":               "^5.12.0",
    "zod":                  "^3.23.0",
    "pino":                 "^9.3.0",
    "pino-pretty":          "^13.1.3",
    "ai":                   "^3.3.0",
    "@ai-sdk/openai":       "^0.0.54",
    "@ai-sdk/anthropic":    "^0.0.44",
    "dotenv":               "^16.4.0",
    "@horizontal-ph/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node":  "^22.0.0",
    "@types/pg":    "^8.11.0",
    "tsx":          "^4.16.0",
    "typescript":   "^5.5.0",
    "vitest":       "^2.0.0"
  }
}